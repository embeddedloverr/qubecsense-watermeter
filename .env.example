# MongoDB connection string.
# Local:   mongodb://127.0.0.1:27017/qubecsense
# Atlas:   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/qubecsense
MONGODB_URI=mongodb://127.0.0.1:27017/qubecsense

# Secret used to sign session JWTs. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-secret-string

# Seed credentials (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@qubecsense.com
SEED_ADMIN_PASSWORD=admin123
SEED_TECH_EMAIL=tech@qubecsense.com
SEED_TECH_PASSWORD=tech123
