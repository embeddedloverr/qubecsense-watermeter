# MongoDB connection string.
# Local:   mongodb://127.0.0.1:27017/qubecsense
# Atlas:   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/qubecsense
MONGODB_URI=mongodb://127.0.0.1:27017/qubecsense

# Secret used to sign session JWTs. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-secret-string

# Seed credentials (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@qubecsense.com
SEED_ADMIN_PASSWORD=admin123
SEED_TECH_EMAIL=tech@qubecsense.com
SEED_TECH_PASSWORD=tech123

# Resident logins created per flat by the seed: username "<prefix>_<flat>"
# with a random one-time password (written to resident-credentials-*.csv).
RESIDENT_USERNAME_PREFIX=rosalyn
RESIDENT_PASSWORD_LENGTH=10

# Live meter data API (the nudron-dashboard deployment, e.g. api.qubecsense.com).
# DATA_API_KEY must match the DATA_API_KEY configured on that server.
DATA_API_URL=https://api.qubecsense.com/api/v1/data
DATA_API_KEY=replace-with-the-data-api-key

# SMTP for emailing resident credentials (npm run email:credentials).
# For Gmail, SMTP_PASS is an app password (Google account → Security →
# App passwords), not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
MAIL_FROM=QubecSense <you@example.com>
APP_URL=https://meters.qubecsense.com

# Secret to authorise the budget-alert cron. Call it from a daily server cron:
#   curl -fsS "https://<app>/api/cron/budget-alerts?key=$CRON_SECRET"
CRON_SECRET=change-me-to-a-long-random-string
